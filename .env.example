ADMIN_USER=deploy

# your local machine public key to ssh into the vps
SSH_PUBLIC_KEY="ssh-ed25519 AAAA-YOUR-KEY"

# Optional: GitHub deploy key on the server for private repo clones/pulls.
# DEPLOY_KEY=/opt/deploy/deploy_key

# Optional: enable Let's Encrypt TLS. Leave unset to stay HTTP-only.
# Domains must already resolve to this server before certbot can succeed.
# CERTBOT_EMAIL=you@example.com

SITE1_DOMAIN=example.com
SITE1_REPO=git@github.com:you/site1.git
# SITE1_ALIASES=

SITE2_DOMAIN=example2.com
SITE2_REPO=git@github.com:you/site2.git
# Extra server_name aliases for SITE2 (space-separated). Use to serve this site
# under additional hostnames, e.g. www.example.com pointing at this site.
# SITE2_ALIASES=www.example.com

APP_NAME=myapp
APP_REPO=git@github.com:you/app.git
# App runtime secrets: place real values at /opt/deploy/<APP_NAME>.env on the
# server; setup.sh copies it to the app dir as .env before `docker compose up`.
