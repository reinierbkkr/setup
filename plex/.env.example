# Copy to /opt/setup/config.env on the server and fill in real values.
# Never commit a real config.env.

# Local admin user (created if missing, gets passwordless sudo).
ADMIN_USER=your_username

# SSH public keys for the admin user. Add one per line as SSH_KEY_1, SSH_KEY_2, etc.
# If any are set, they are added to authorized_keys and password auth is disabled.
# Leave all unset to keep password auth.
# Get your key with: cat ~/.ssh/id_ed25519.pub (or id_rsa.pub)
SSH_KEY_1=
# SSH_KEY_2=

# Optional: Plex claim token to auto-link server to your Plex account.
# Get one at https://www.plex.tv/claim — expires in 4 minutes, so grab it right before running.
# Leave unset to link manually via Plex Web after setup.
PLEX_CLAIM=

# Path where your media lives (mounted drive, NAS mount point, etc.).
# plex user gets ownership. Defaults to /media/plex if unset.
MEDIA_PATH=/media/plex

# Static IP — set to skip DHCP (faster boot, stable address for Plex/Tailscale).
# STATIC_IP must include CIDR prefix. Leave unset to keep DHCP.
STATIC_IP=192.168.1.5/24
GATEWAY=192.168.1.1
# DNS=1.1.1.1, 8.8.8.8
